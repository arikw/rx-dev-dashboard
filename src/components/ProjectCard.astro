---
import type { Project } from '../types/project';
import { formatStat } from '../lib/aggregate-stats';
import ProjectThumb from './ProjectThumb.astro';

interface Props {
  project: Project;
  size?: 'compact' | 'featured';
}
const { project: p, size = 'compact' } = Astro.props;
const base = import.meta.env.BASE_URL;

const statLines: string[] = [];
if (p.stats.stars !== undefined && p.stats.stars > 0) statLines.push(`★ ${formatStat(p.stats.stars)}`);
if (p.stats.users !== undefined && p.stats.users > 0) statLines.push(`${formatStat(p.stats.users)} users`);
if (p.stats.pulls !== undefined && p.stats.pulls > 0) statLines.push(`${formatStat(p.stats.pulls)} pulls`);
if (p.stats.downloadsMonthly !== undefined && p.stats.downloadsMonthly > 0) statLines.push(`${formatStat(p.stats.downloadsMonthly)}/mo`);
if (p.stats.rating !== undefined && p.stats.ratingCount) {
  statLines.push(`${p.stats.rating.toFixed(1)}★ (${formatStat(p.stats.ratingCount)})`);
}

const detailHref = p.hasDetail ? `${base}${p.id}/` : null;
---
<article class={`card card--${size}`} data-tags={p.tags.join(',')} data-source={p.source}>
  <ProjectThumb project={p} />
  <header class="card-head">
    <a class="card-title" href={p.url} rel="noopener" target="_blank">
      <h3>{p.title}</h3>
      <span class="card-arrow" aria-hidden="true">↗</span>
    </a>
    <span class={`card-source card-source--${p.source}`}>{p.source}</span>
  </header>

  <p class="card-badges">
    {p.kind && <span class={`card-badge card-badge--kind card-badge--kind-${p.kind}`}>{p.kind}</span>}
    {p.openSource && (
      <a
        class="card-badge card-badge--oss"
        href={p.sourceUrl ?? p.url}
        target="_blank"
        rel="noopener"
        title={p.sourceUrl ? `Source: ${p.sourceUrl}` : 'Open source'}
      >open source</a>
    )}
  </p>

  {p.description && <p class="card-desc">{p.description}</p>}

  {statLines.length > 0 && (
    <p class="card-stats">{statLines.join(' · ')}</p>
  )}

  {p.tags.length > 0 && (
    <p class="card-tags">
      {p.tags.slice(0, 4).map((t) => <span class="card-tag">{t}</span>)}
    </p>
  )}

  {detailHref && (
    <a class="card-detail-link" href={detailHref}>Details →</a>
  )}
</article>
