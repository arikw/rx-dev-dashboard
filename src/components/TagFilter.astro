---
interface TagEntry {
  name: string;
  count: number;
}
interface Props {
  primary: TagEntry[];
  overflow: TagEntry[];
  totalCount: number;
}
const { primary, overflow, totalCount } = Astro.props;
const hasOverflow = overflow.length > 0;
---
<div class="tag-filter" role="group" aria-label="Filter projects by tag">
  <button
    type="button"
    class="tag-chip"
    data-tag-filter=""
    aria-pressed="true"
  >
    All <span class="tag-count">{totalCount}</span>
  </button>
  {primary.map(({ name, count }) => (
    <button
      type="button"
      class="tag-chip"
      data-tag-filter={name}
      aria-pressed="false"
    >
      {name} <span class="tag-count">{count}</span>
    </button>
  ))}
  {hasOverflow && (
    <>
      {overflow.map(({ name, count }) => (
        <button
          type="button"
          class="tag-chip tag-chip--overflow"
          data-tag-filter={name}
          aria-pressed="false"
          hidden
        >
          {name} <span class="tag-count">{count}</span>
        </button>
      ))}
      <button
        type="button"
        class="tag-chip tag-chip-toggle"
        data-tag-toggle
        aria-expanded="false"
        data-overflow-count={overflow.length}
      >
        + {overflow.length} more
      </button>
    </>
  )}
</div>
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const filter = document.querySelector<HTMLElement>('.tag-filter');
    if (!filter) return;
    const toggle = filter.querySelector<HTMLButtonElement>('[data-tag-toggle]');
    if (!toggle) return;
    const overflowChips = filter.querySelectorAll<HTMLButtonElement>('.tag-chip--overflow');
    const count = parseInt(toggle.dataset.overflowCount ?? '0', 10);
    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      const next = !expanded;
      toggle.setAttribute('aria-expanded', String(next));
      toggle.textContent = next ? 'Fewer tags' : `+ ${count} more`;
      overflowChips.forEach((c) => {
        if (next) c.removeAttribute('hidden');
        else c.setAttribute('hidden', '');
      });
    });
  });
</script>
